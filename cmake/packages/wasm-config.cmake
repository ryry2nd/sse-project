set(WAMR_BUILD_INTERP 0 CACHE BOOL "" FORCE)
set(WAMR_BUILD_AOT 0 CACHE BOOL "" FORCE)
set(WAMR_BUILD_JIT 0 CACHE BOOL "" FORCE)
set(WAMR_BUILD_FAST_JIT 1 CACHE BOOL "" FORCE)
set(WAMR_BUILD_LIBC_WASI 1 CACHE BOOL "" FORCE)
set(WAMR_BUILD_LIBC_BUILTIN 1 CACHE BOOL "" FORCE)
set(WAMR_ENABLE_THREAD_MGR 1 CACHE BOOL "" FORCE)
set(WAMR_BUILD_SAMPLES 0 CACHE BOOL "" FORCE)
set(WAMR_BUILD_TESTS 0 CACHE BOOL "" FORCE)
set(WAMR_BUILD_SIMD 0 CACHE BOOL "" FORCE)

# platform (cross-platform safe)
if(WIN32)
    set(WAMR_BUILD_PLATFORM windows CACHE STRING "" FORCE)
elseif(APPLE)
    set(WAMR_BUILD_PLATFORM darwin CACHE STRING "" FORCE)
elseif(ANDROID)
    set(WAMR_BUILD_PLATFORM android CACHE STRING "" FORCE)
elseif(FREEBSD)
    set(WAMR_BUILD_PLATFORM freebsd CACHE STRING "" FORCE)
elseif(ESP_PLATFORM)
    set(WAMR_BUILD_PLATFORM esp32 CACHE STRING "" FORCE)
elseif(CMAKE_SYSTEM_NAME STREQUAL "AliOS")
    set(WAMR_BUILD_PLATFORM alios CACHE STRING "" FORCE)
else()
    set(WAMR_BUILD_PLATFORM linux CACHE STRING "" FORCE)
endif()

add_subdirectory(libs/wasm)

add_library(wamr::wamr ALIAS vmlib)
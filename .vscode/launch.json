{
    "version": "0.2.0",
    "configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Launch",
			"program": "${workspaceFolder}/build/linux-Debug/sse-project/bin/main",
			"preLaunchTask": "Run build.sh",
			"args": [],
			"cwd": "${workspaceFolder}/build/linux-Debug/sse-project",
			"console": "integratedTerminal",
			"env": {
				"FORCE_COLOR": "1",
				"TERM": "xterm-256color"
			}
		}
    ]
}